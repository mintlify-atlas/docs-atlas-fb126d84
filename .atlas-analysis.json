    "DELETE /cart/{cart} - Remove from cart",
    "POST /orderconfirm - Create order",
    "Admin: /admin/users, /admin/foodmenu, /admin/chefs, /admin/reservations, /admin/tables, /admin/orders",
    "Chef: /admin/foods, /admin/profile",
    "Waiter: /admin/tables, /admin/reservations",
    "Command: php artisan reservations:check"
